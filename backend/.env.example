# ===============================================
# VARIÁVEIS DE AMBIENTE - BACKEND (SocialDown)
# ===============================================

# Nome da aplicação
APP_NAME=SocialDown API

# Modo de debug (True/False)
DEBUG=False

# Versão da API
API_VERSION=v1

# Rate limiting (requisições por minuto)
RATE_LIMIT_REQUESTS=10

# CORS - Adicione suas origens separadas por vírgula
# Exemplos:
# CORS_ORIGINS=http://localhost:3000,https://socialdown.vercel.app
